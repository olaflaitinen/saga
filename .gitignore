# Python byte-compiled and cache files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution and packaging artifacts
.eggs/
*.egg-info/
dist/
build/
wheels/
*.whl
*.tar.gz
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Test and analysis caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc
.hypothesis/

# Jupyter notebook checkpoints
.ipynb_checkpoints/
*.executed.ipynb

# Editor and IDE artifacts
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# MkDocs build output
site/

# Conda environment artifacts
conda-lock.yml
*.conda

# LISA microdata: the real data directory must never contain protected microdata
# in this public repository. This rule is enforced both here and in pre-commit hooks.
data/real/*
!data/real/README.md

# Model checkpoint files (large binary artifacts versioned via DVC or Zenodo, not git)
checkpoints/
*.pt
*.pth
*.ckpt

# Log files
logs/
*.log
*.log.*

# Temporary and scratch files
tmp/
scratch/
*.tmp
